generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROFESOR
  ALUMNO
}

model User {
  id        String   @id @default(uuid())
  legajo    String   @unique
  password  String
  name      String
  role      Role     @default(ALUMNO)
  division  String?  // Ejemplo: "2° 1ra"
  progress  ReadingProgress[]
  trophies  Trophy[]
  assignments TextAssignment[]
  createdAt DateTime @default(now())
}

model Text {
  id        String   @id @default(uuid())
  title     String
  author    String
  content   String
  level     String   // "Crítico", "Básico", "Medio"
  year      Int      // 1, 2, 3, 4, 5
  challenges Challenge[]
  progress  ReadingProgress[]
  assignments TextAssignment[]
}

model Challenge {
  id         String   @id @default(uuid())
  textId     String
  text       Text     @relation(fields: [textId], references: [id])
  question   String
  options    String   // JSON con las opciones
  correctIdx Int      // Índice de la opción correcta
}

// Asignación de textos a cursos o alumnos individuales
model TextAssignment {
  id        String   @id @default(uuid())
  textId    String
  text      Text     @relation(fields: [textId], references: [id], onDelete: Cascade)
  mode      String   // "EVALUACION" o "PRACTICA"

  // Target: curso completo o alumno individual
  division  String?  // Ej: "2° 1ra" → todos los alumnos de ese curso
  userId    String?  // Alumno individual
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ReadingProgress {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  textId     String
  text       Text     @relation(fields: [textId], references: [id])
  status     String   // "PENDIENTE", "INICIADO", "COMPLETADO"
  mode       String   @default("PRACTICA") // "EVALUACION" o "PRACTICA"
  audioUrl   String?  // URL de Vercel Blob
  score      Int      @default(0)
  
  // Feedback manual del Profesor
  feedback   String?
  grade      Int?     // Nota o puntaje dado por el profesor
  
  // Análisis de IA (OpenAI Whisper + GPT)
  aiScore    Int?
  aiAnalysis Json?    // JSON con errores, palabras omitidas, etc.

  updatedAt  DateTime @updatedAt
}

model Trophy {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  icon      String
  earnedAt  DateTime @default(now())
}
